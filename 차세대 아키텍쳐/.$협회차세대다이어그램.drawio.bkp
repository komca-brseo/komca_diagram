                <mxCell id="_SEV7fE334V-cIiT9-ow-1" value="회원 본인이 접수여부를 쉽게 확인할 수 있도록(등록되지 않았는데 등록 안하냐고 민원 발생)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6542.4" y="869.34" width="183" height="77" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-2" value="정산 및 분배기간(11~23일)동안 자료 등록/수정 되지않음" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6535.4" y="1286.34" width="80" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-3" value="온라인 신청 시 2차저작물 표기 기능 추가 및 저작권 소멸여부 확인 필요" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6535.4" y="1130.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-4" value="반려문자 이력관리 및 기존 신청 제출 첨부파일 확인 가능하도록 신청 이력 관리" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6195.4" y="1046.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-5" value="대량등록의 경우에도 자동으로 곡마다의 반려 사유가 알림톡에 등록될 수 있도록, 일괄반려또한 가능하도록" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6195.4" y="1146.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-6" value="주로 발생하는 반려 사유에 대하여 템플릿화, 코드화 검토" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6065.4" y="1046.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-7" value="기등록곡 유무 확인을 수기로 진행하지 않기 위해 IPI연동, 다양한 부제목 설정" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6235.4" y="1296.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-8" value="특수문자 등의 기준이 필요하며, 시스템상에서 다국어 및 멀티바이트 문자를 지원하도록" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6815.4" y="1623.34" width="80" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-9" value="곡별 계약의 경우 곡별리스트를 PDF로 접수받고있는데 수기 검수를 해야하므로 다른 양식 설정할 수 있도록" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6795.4" y="1289.34" width="100" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-10" value="CWR 곡등록 안정성(CWR 유효성 검증 모듈 필요)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="7145.4" y="1479.34" width="110" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-11" value="&lt;div&gt;엑셀업로드시 경합 이력관리 로직 참고하여 CWR 경합이력관리또한 필요함&lt;br&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6795.4" y="1459.34" width="100" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-12" value="CWR EXPORT 기능 필요" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="7145.4" y="1699.34" width="100" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-13" value="베토벤 등 많은 2차저작물이 발생하는 경우 관리" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6555.4" y="1001.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-14" value="국외저작자의 경우 프로그램 내에서 계약 이력을 관리할 수 없어 전산팀이 지분 수작업으로 변경" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="6805.4" y="1793.34" width="120" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-15" value="협회 회원이였다가 탈퇴 후 해외단체로 등록하는 경우 문제 발생, 회원의 입회,신탁계약 체결 및 해지 이력 관리 필요" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
