                <mxCell id="6-mfiE0Ln5hXqk0lmSrI-81" value="100 징수&lt;div&gt;100 분배&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;40 SP1&lt;/div&gt;&lt;div&gt;10 OP1&lt;/div&gt;&lt;div&gt;30 SP2&lt;/div&gt;&lt;div&gt;5 OP2&lt;/div&gt;&lt;div&gt;15 해외단체&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;fontSize=30;" parent="6-mfiE0Ln5hXqk0lmSrI-88" vertex="1">
