                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-18" value="명확히 기등록곡이 존재하는 경우가 아니면, 대부분의 곡은 가등록 처리될 것" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
