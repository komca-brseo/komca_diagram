                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-16" value="지급보류 설정은 KOSMOS에서 가능하나, 지급보류 설정/해제 이력관리 필요" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
                    <mxGeometry x="5553" y="1188.34" width="130" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="_SEV7fE334V-cIiT9-ow-17" value="CWR 파일 자체 유효성 검증,&lt;br&gt;IPI 코드 검증 등" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;size=18;fillColor=#fff2cc;strokeColor=#d6b656;" parent="hG1gKqRtoNm6q-UcaIaC-2" vertex="1">
